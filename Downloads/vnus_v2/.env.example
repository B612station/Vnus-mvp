# Copier ce fichier en .env.local pour le dev local
# Sur Vercel : ajouter ces variables dans Settings → Environment Variables

# Supabase (frontend - clé publique anon, ok à exposer)
VITE_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Anthropic (côté serveur uniquement - NE PAS préfixer avec VITE_)
ANTHROPIC_API_KEY=sk-ant-...
